# =============================================================================
# World Cup 2026 Prediction League — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres connection string for SQLAlchemy (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/wc2026

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Supabase project URL (REST API base)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — safe to expose to the frontend
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — backend only, never expose to frontend
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Secret for signing access tokens (HS256, 24h TTL) — min 32 random chars
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Secret for signing refresh tokens (30d TTL) — min 32 random chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# -----------------------------------------------------------------------------
# Football Data API
# -----------------------------------------------------------------------------

# football-data.org API key (free tier)
# Register at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# -----------------------------------------------------------------------------

# VAPID public key — exposed to frontend for push subscription
VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID private key — backend only
VAPID_PRIVATE_KEY=your-vapid-private-key

# Contact email for VAPID (shown to push services)
VAPID_CONTACT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Allowed CORS origin for the backend (frontend URL)
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# -----------------------------------------------------------------------------

# Sentry DSN for the FastAPI backend
SENTRY_DSN_BACKEND=

# Sentry DSN for the React frontend (can be left empty for local dev)
SENTRY_DSN_FRONTEND=

# -----------------------------------------------------------------------------
# CI / Tooling
# -----------------------------------------------------------------------------

# GitHub personal access token — used by phase close-out to poll CI status
GITHUB_TOKEN=your-github-personal-access-token
